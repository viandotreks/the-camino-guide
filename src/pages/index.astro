---
// index.astro — homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const routes = await getCollection('routes', ({ data }) => data.published);
---

<BaseLayout
  title="The Camino Guide"
  description="The definitive English-language guide to the Camino de Santiago. Stage-by-stage coverage, practical services, and cultural depth — all verified on the ground."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <a href="/" class="hero__logo-wrap" aria-label="The Camino Guide">
        <img src="/logo.svg" alt="The Camino Guide" class="hero__logo" />
      </a>
      <p class="hero__subtitle">
        Stage-by-stage coverage of the Camino's routes — distances, services, culture —
        written in plain English and verified on the ground.
      </p>
      <a href="/french-way" class="hero__cta">Start with the French Way →</a>
    </div>
  </section>

  <!-- Routes -->
  <section class="routes-section container">
    <h2 class="section-eyebrow routes-section__title">Routes</h2>
    <div class="routes-grid">
      {routes.map(route => {
        const r = route.data;
        return (
          <a href={`/${route.slug}`} class="route-card">
            <p class="route-card__title">{r.title}</p>
            <p class="route-card__meta cg-meta">{r.total_distance_km} km &nbsp;·&nbsp; {r.total_stages} stages</p>
            <p class="route-card__endpoints cg-meta">{r.start_point} → {r.end_point}</p>
          </a>
        );
      })}
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: 64px var(--gutter-mob) 56px;
    text-align: center;
    border-bottom: 1px solid var(--rule);
  }

  .hero__content {
    max-width: 600px;
    margin: 0 auto;
  }

  .hero__logo-wrap {
    display: block;
    margin-bottom: 24px;
  }

  .hero__logo {
    height: 100px;
    width: auto;
    margin: 0 auto;
  }

  .hero__subtitle {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink-3);
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .hero__cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-ink);
    text-decoration: none;
    letter-spacing: 0.01em;
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
  }

  .hero__cta:hover { color: var(--accent); }

  /* Routes section */
  .routes-section {
    padding-top: 40px;
    padding-bottom: 48px;
  }

  .routes-section__title {
    margin-bottom: 20px;
  }

  .routes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .routes-grid {
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    }
  }

  .route-card {
    display: block;
    background: var(--paper);
    padding: 20px 20px;
    text-decoration: none;
    color: inherit;
    transition: background 120ms;
  }

  .route-card:hover { background: var(--paper-2); }

  .route-card__title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .route-card__meta {
    color: var(--ink-3);
    margin-bottom: 2px;
  }

  .route-card__endpoints {
    color: var(--accent-ink);
    margin-top: 6px;
  }
</style>
