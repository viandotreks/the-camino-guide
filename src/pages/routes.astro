---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const routes = await getCollection('routes', ({ data }) => data.published);
---

<BaseLayout
  title="Routes"
  description="All Camino de Santiago routes covered by The Camino Guide — stage-by-stage, in plain English."
  activeRoute=""
>

  <div class="page-header page-header--simple" data-pagefind-ignore>
    <div class="container">
      <h1 class="page-header__h1">Routes</h1>
      <p class="page-header__desc">Every route covered stage-by-stage, with distances, services, and cultural depth.</p>
    </div>
  </div>

  <section class="container listing-section">
    {routes.length === 0 ? (
      <p class="listing-empty">No routes published yet.</p>
    ) : (
      <div class="routes-grid">
        {routes.map(route => {
          const r = route.data;
          return (
            <a href={`/${route.slug}`} class="route-card">
              <p class="route-card__title">{r.title}</p>
              <p class="route-card__meta cg-meta">{r.total_distance_km} km &nbsp;·&nbsp; {r.total_stages} stages</p>
              {r.start_point && r.end_point && (
                <p class="route-card__endpoints cg-meta">{r.start_point} → {r.end_point}</p>
              )}
            </a>
          );
        })}
      </div>
    )}
  </section>

</BaseLayout>

<style>
  .page-header--simple {
    padding: 48px 0 40px;
    border-bottom: 1px solid var(--rule);
  }

  .page-header__h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }

  .page-header__desc {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink-3);
    max-width: 520px;
    line-height: 1.6;
  }

  .listing-section {
    padding-top: 40px;
    padding-bottom: 64px;
  }

  .listing-empty {
    font-family: var(--sans);
    color: var(--ink-3);
  }

  .routes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .routes-grid {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
  }

  .route-card {
    display: block;
    background: var(--paper);
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: background 120ms;
  }

  .route-card:hover { background: var(--paper-2); }

  .route-card__title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .route-card__meta {
    color: var(--ink-3);
    margin-bottom: 2px;
  }

  .route-card__endpoints {
    color: var(--accent-ink);
    margin-top: 6px;
  }
</style>
