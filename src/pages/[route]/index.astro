---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const routes = await getCollection('routes', ({ data }) => data.published);
  return routes.map((route) => ({
    params: { route: route.slug },
    props:  { route },
  }));
}

const { route } = Astro.props;
const { Content } = await route.render();
const r = route.data;

const allStages = await getCollection('stages', ({ data }) =>
  data.route === route.slug && data.published
);
const stages = allStages.sort((a, b) => a.data.order - b.data.order);

const difficultyLabel: Record<string, string> = {
  easy:        'Easy',
  moderate:    'Moderate',
  hard:        'Hard',
  'very-hard': 'Very Hard',
};
---

<BaseLayout
  title={r.title}
  description={r.seo_description}
  ogType="article"
  breadcrumb="Routes"
  breadcrumbUrl="/"
  activeRoute={route.slug}
  pageType="route"
>

  <!-- Route header -->
  <header class="route-header">
    <div class="page-header__eyebrow" style="margin-bottom: 10px;">
      <span class="cg-eyebrow">Camino de Santiago</span>
    </div>
    <h1>{r.title}</h1>
    <div class="route-header__meta">
      <span class="route-header__meta-item">{r.total_distance_km} km total</span>
      <span class="route-header__meta-item">{r.total_stages} stages</span>
      <span class="route-header__meta-item">{r.start_point} → {r.end_point}</span>
    </div>
  </header>

  <!-- Route overview prose -->
  <div class="container" style="padding-top: 24px; padding-bottom: 32px;">
    <div class="prose" style="max-width: 640px;">
      <Content />
    </div>
  </div>

  <!-- Stage list -->
  <div class="container" style="padding-bottom: 0;">
    <h2 class="section-eyebrow" style="margin-bottom: 16px;">Stages</h2>
  </div>

  <div class="stage-list">
    {stages.map((stage) => {
      const sd = stage.data;
      const gainStr = `+${sd.elevation_gain_m.toLocaleString('en-US')} m`;
      const lossStr = `−${sd.elevation_loss_m.toLocaleString('en-US')} m`;
      return (
        <a
          href={`/${sd.route}/${stage.slug}`}
          class="stage-row"
        >
          <span class="stage-row__num">{String(sd.order).padStart(2, '0')}</span>
          <span>
            <span class="stage-row__title">{sd.title}</span>
            <span class="stage-row__meta">
              {sd.distance_km} km · {gainStr} / {lossStr}
            </span>
          </span>
          <span class={`diff-badge diff-badge--${sd.difficulty}`}>
            <span class="diff-badge__dot"></span>
            {difficultyLabel[sd.difficulty]}
          </span>
        </a>
      );
    })}
  </div>

</BaseLayout>
