---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const routes = await getCollection('routes', ({ data }) => data.published);
  return routes.map((route) => ({
    params: { route: route.slug },
    props:  { route },
  }));
}

const { route } = Astro.props;
const r = route.data;

const allStages = await getCollection('stages', ({ data }) =>
  data.route === route.slug && data.published
);
const stages = allStages.sort((a, b) => a.data.order - b.data.order);

// Assign A/B/C letters to stages that share the same order number
const orderCount: Record<number, number> = {};
stages.forEach(s => { orderCount[s.data.order] = (orderCount[s.data.order] || 0) + 1; });
const orderLetterIdx: Record<number, number> = {};
const stagesWithLetters = stages.map(s => {
  const o = s.data.order;
  let letter = '';
  if (orderCount[o] > 1) {
    orderLetterIdx[o] = orderLetterIdx[o] ?? 0;
    letter = String.fromCharCode(65 + orderLetterIdx[o]);
    orderLetterIdx[o]++;
  }
  return { stage: s, letter };
});

const allLocalities = await getCollection('localities', ({ data }) =>
  data.route === route.slug && data.published
);
const localities = allLocalities.sort((a, b) => b.data.km_to_santiago - a.data.km_to_santiago);
---

<BaseLayout
  title={r.title}
  description={r.seo_description}
  ogType="article"
  breadcrumb="Routes"
  breadcrumbUrl="/"
  activeRoute={route.slug}
  pageType="route"
>

  <span data-pagefind-meta="type:Route" hidden></span>

  <!-- Route header -->
  <header class="route-header" data-pagefind-ignore>
    <div class="page-header__eyebrow" style="margin-bottom: 10px;">
      <span class="cg-eyebrow">Camino de Santiago</span>
    </div>
    <h1>{r.title}</h1>
    <div class="route-header__meta">
      <span class="route-header__meta-item">{r.total_distance_km} km total</span>
      <span class="route-header__meta-item">{r.total_stages} stages</span>
      <span class="route-header__meta-item">{r.start_point} → {r.end_point}</span>
    </div>
  </header>

  <!-- Route intro from Summary property -->
  {r.subtitle && (
    <div class="container" style="padding-top: 24px; padding-bottom: 32px;">
      <p class="route-intro">{r.subtitle}</p>
    </div>
  )}

  <!-- Tab bar -->
  <div class="tab-bar tab-bar--2" role="tablist" id="route-tabs" data-pagefind-ignore>
    <button class="tab-bar__btn" role="tab" data-tab="stages" aria-selected="true" aria-controls="tab-stages">
      Stages
    </button>
    <button class="tab-bar__btn" role="tab" data-tab="localities" aria-selected="false" aria-controls="tab-localities">
      Localities
    </button>
  </div>

  <!-- Tab: Stages -->
  <div id="tab-stages" class="tab-panel" data-tab="stages" role="tabpanel">
    <div class="stage-list">
      {stagesWithLetters.map(({ stage, letter }) => {
        const sd = stage.data;
        const mi = (sd.distance_km * 0.621371).toFixed(1);
        return (
          <a href={`/${sd.route}/${stage.slug}`} class="stage-row">
            <span class="stage-row__num">{String(sd.order).padStart(2, '0')}{letter}</span>
            <span class="stage-row__content">
              <span class="stage-row__title">{sd.title}</span>
              <span class="stage-row__meta">{sd.distance_km} km · {mi} mi</span>
            </span>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Tab: Localities -->
  <div id="tab-localities" class="tab-panel" data-tab="localities" role="tabpanel" hidden>
    <div class="stage-list">
      {localities.map((loc) => {
        const ld = loc.data;
        return (
          <a href={`/${ld.route}/${loc.slug}`} class="stage-row">
            <span class="stage-row__num stage-row__num--km">{ld.km_to_santiago}</span>
            <span class="stage-row__content">
              <span class="stage-row__title">{ld.name}</span>
              <span class="stage-row__meta">{ld.km_to_santiago} km to Santiago</span>
            </span>
          </a>
        );
      })}
    </div>
  </div>

</BaseLayout>

<script>
  const tabBar = document.getElementById('route-tabs');
  if (tabBar) {
    const btns   = tabBar.querySelectorAll<HTMLButtonElement>('.tab-bar__btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        btns.forEach(b => b.setAttribute('aria-selected', String(b === btn)));
        panels.forEach(p => { p.hidden = p.dataset.tab !== target; });
      });
    });
  }
</script>
