---
import { getCollection } from 'astro:content';
import StageLayout from '../../layouts/StageLayout.astro';
import LocalityLayout from '../../layouts/LocalityLayout.astro';

export async function getStaticPaths() {
  const [stages, localities] = await Promise.all([
    getCollection('stages',     ({ data }) => data.published),
    getCollection('localities', ({ data }) => data.published),
  ]);

  return [
    ...stages.map((stage) => ({
      params: { route: stage.data.route, slug: stage.slug },
      props:  { stage, locality: null },
    })),
    ...localities.map((locality) => ({
      params: { route: locality.data.route, slug: locality.slug },
      props:  { stage: null, locality },
    })),
  ];
}

const { stage, locality } = Astro.props;

// Render the appropriate content component
const { Content: StageContent } = stage    ? await stage.render()    : { Content: null };
const { Content: LocalityContent } = locality ? await locality.render() : { Content: null };

const s = stage?.data;
---

{locality ? (
  <LocalityLayout locality={locality}>
    {LocalityContent && <LocalityContent />}
  </LocalityLayout>
) : (
  <StageLayout stage={stage!}>

    <!-- In short -->
    <section class="in-short-section">
      <h2 class="section-eyebrow section-eyebrow--accent">In short</h2>
      <div class="in-short-text prose" set:html={s!.in_short} />
    </section>

    <!-- Watch out for -->
    {s!.watch_out_for.length > 0 && (
      <aside class="watch-out">
        <div class="watch-out__header">
          <span class="watch-out__icon" aria-hidden>!</span>
          <span class="watch-out__heading">Watch out for</span>
        </div>
        <ul class="watch-out__list">
          {s!.watch_out_for.map(item => <li set:html={item} />)}
        </ul>
      </aside>
    )}

    <!-- Step by step -->
    <section class="stage-section">
      <h2 class="section-eyebrow section-eyebrow--accent">Step by step</h2>
      <div class="prose">
        {StageContent && <StageContent />}
      </div>
    </section>

    <!-- For bikers -->
    {s!.for_bikers && (
      <aside class="for-bikers">
        <div class="for-bikers__header">
          <svg width="18" height="14" viewBox="0 0 24 16" fill="none" aria-hidden style="flex-shrink: 0;">
            <circle cx="5" cy="11" r="4" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="19" cy="11" r="4" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5 11 L11 11 L15 4 L19 11 M11 4 L15 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="11" cy="4" r="0.8" fill="currentColor"/>
          </svg>
          <span class="for-bikers__heading">For bikers</span>
        </div>
        <div set:html={s!.for_bikers} />
      </aside>
    )}

  </StageLayout>
)}
