---
import { getCollection } from 'astro:content';
import StageLayout from '../../layouts/StageLayout.astro';

export async function getStaticPaths() {
  const stages = await getCollection('stages', ({ data }) => data.published);
  return stages.map((stage) => ({
    params: {
      route: stage.data.route,
      slug:  stage.slug,
    },
    props: { stage },
  }));
}

const { stage } = Astro.props;
const { Content } = await stage.render();
const s = stage.data;
---

<StageLayout stage={stage}>

  <!-- In short -->
  <section class="in-short-section">
    <h2 class="section-eyebrow section-eyebrow--accent">In short</h2>
    <p class="in-short-text">{s.in_short}</p>
  </section>

  <!-- Watch out for -->
  {s.watch_out_for.length > 0 && (
    <aside class="watch-out">
      <div class="watch-out__header">
        <span class="watch-out__icon" aria-hidden>!</span>
        <span class="watch-out__heading">Watch out for</span>
      </div>
      <ul class="watch-out__list">
        {s.watch_out_for.map(item => <li>{item}</li>)}
      </ul>
    </aside>
  )}

  <!-- Step by step -->
  <section class="stage-section">
    <h2 class="section-eyebrow section-eyebrow--accent">Step by step</h2>
    <div class="prose">
      <Content />
    </div>
  </section>

  <!-- For bikers -->
  {s.for_bikers && (
    <aside class="for-bikers">
      <div class="for-bikers__header">
        <svg width="18" height="14" viewBox="0 0 24 16" fill="none" aria-hidden style="flex-shrink: 0;">
          <circle cx="5" cy="11" r="4" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="19" cy="11" r="4" stroke="currentColor" stroke-width="1.2"/>
          <path d="M5 11 L11 11 L15 4 L19 11 M11 4 L15 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="11" cy="4" r="0.8" fill="currentColor"/>
        </svg>
        <span class="for-bikers__heading">For bikers</span>
      </div>
      <p>{s.for_bikers}</p>
    </aside>
  )}

</StageLayout>
