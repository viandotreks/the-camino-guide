---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locality: CollectionEntry<'localities'>;
  activeTab?: 'guide' | 'lodging';
}

const { locality, activeTab = 'guide' } = Astro.props;
const l = locality.data;

const metaCells = [
  { key: 'Region',     val: l.region ?? '—' },
  { key: 'Population', val: l.population != null ? l.population.toLocaleString('en-US') : '—' },
  { key: 'Languages',  val: l.languages.join(', ') },
];

const services = [
  l.has_albergue    && 'Pilgrim hostel',
  l.has_hotel       && 'Hotel',
  l.has_atm         && 'ATM',
  l.has_pharmacy    && 'Pharmacy',
  l.has_supermarket && 'Supermarket',
  l.has_medical     && 'Medical centre',
].filter(Boolean) as string[];
---

<BaseLayout
  title={l.name}
  description={l.seo_description ?? `${l.name}${l.name_alt ? ` (${l.name_alt})` : ''} on the Camino de Santiago. ${l.km_to_santiago} km to Santiago.`}
  breadcrumb="French Way · Towns"
  breadcrumbUrl={`/${l.route}`}
  activeRoute={l.route}
  pageType="locality"
>

  <!-- Page header -->
  <header class="locality-header">
    <div class="page-header__eyebrow" style="margin-bottom: 8px;">
      <a href={`/${l.route}`} class="cg-eyebrow" style="color: var(--accent-ink); text-decoration: none;">
        {l.route === 'french-way' ? 'French Way' : l.route}
      </a>
      <span class="page-header__eyebrow-sep cg-eyebrow">·</span>
      <span class="cg-eyebrow">Town</span>
    </div>

    <h1>{l.name}</h1>
    {l.name_alt && (
      <div class="locality-header__alt cg-data">({l.name_alt})</div>
    )}

    <!-- km to Santiago — prominent -->
    <div class="km-box">
      <span class="km-box__label">to Santiago</span>
      <span>
        <span class="km-box__num">{l.km_to_santiago.toLocaleString('en-US')}</span>
        <span class="km-box__unit">km</span>
      </span>
    </div>

    <!-- Secondary data grid -->
    <div class="locality-meta-grid">
      {metaCells.map(cell => (
        <div class="locality-meta-cell">
          <div class="locality-meta-cell__key">{cell.key}</div>
          <div class="locality-meta-cell__val">{cell.val}</div>
        </div>
      ))}
    </div>
  </header>

  <!-- Map -->
  <div class="map-area">
    {l.map_embed ? (
      <Fragment set:html={l.map_embed} />
    ) : (
      <div class="map-area__placeholder">Outdooractive · Map embed</div>
    )}
  </div>

  <!-- Tab bar -->
  <div class="tab-bar tab-bar--2" role="tablist" id="locality-tabs">
    <button
      class="tab-bar__btn"
      role="tab"
      aria-selected={activeTab === 'guide' ? 'true' : 'false'}
      data-tab="guide"
    >
      The Guide
    </button>
    <button
      class="tab-bar__btn"
      role="tab"
      aria-selected={activeTab === 'lodging' ? 'true' : 'false'}
      data-tab="lodging"
    >
      Lodging &amp; Services
    </button>
  </div>

  <!-- Content -->
  <div class="container" style="padding-top: 20px; padding-bottom: 8px;">

    <!-- Tab panel: Guide -->
    <div id="tab-guide" class="tab-panel" data-tab="guide" role="tabpanel">
      <slot />
      {l.last_verified && (
        <div class="verified-block">
          <div class="verified-block__row">
            <span class="verified-block__date">Verified {l.last_verified}</span>
          </div>
        </div>
      )}
    </div>

    <!-- Tab panel: Lodging & Services -->
    <div id="tab-lodging" class="tab-panel" data-tab="lodging" role="tabpanel" hidden>

      {services.length > 0 ? (
        <>
          <p class="services-intro">Services available in {l.name}.</p>
          <ul style="list-style: none; padding: 0; margin: 0 0 24px; border-top: 1px solid var(--rule-soft);">
            {services.map(svc => (
              <li style="display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--rule-soft); font-family: var(--sans); font-size: 14px; color: var(--ink-2);">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--diff-easy); flex-shrink: 0;"></span>
                {svc}
              </li>
            ))}
          </ul>
        </>
      ) : (
        <p class="services-intro">Limited services — plan ahead.</p>
      )}

      <div class="coming-soon">
        <div class="coming-soon__heading">Accommodation listings</div>
        <p>Detailed accommodation data for this town is being added.</p>
        <div class="coming-soon__caption">In preparation — 2026</div>
      </div>

    </div>

  </div>

</BaseLayout>

<!-- Tab switching -->
<script>
  const tabBar = document.getElementById('locality-tabs');
  if (tabBar) {
    const btns   = tabBar.querySelectorAll<HTMLButtonElement>('.tab-bar__btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        btns.forEach(b => b.setAttribute('aria-selected', String(b === btn)));
        panels.forEach(p => { p.hidden = p.dataset.tab !== target; });
      });
    });
  }
</script>
