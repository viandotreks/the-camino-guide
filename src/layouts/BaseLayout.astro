---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  breadcrumb?: string;
  breadcrumbUrl?: string;
  activeRoute?: string;
  pageType?: 'home' | 'route' | 'stage' | 'locality';
}

const {
  title,
  description = 'The definitive English-language guide to the Camino de Santiago.',
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  breadcrumb,
  breadcrumbUrl = '/',
  activeRoute,
  pageType = 'home',
} = Astro.props;

const siteName = 'The Camino Guide';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const navLinks = [
  { label: 'Routes',      href: '/routes',      key: 'routes' },
  { label: 'Localities',  href: '/localities',  key: 'localities' },
  { label: 'Services',    href: '/services',    key: 'services' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type"        content={ogType} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:site_name"   content={siteName} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: Source Serif 4 + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu" data-pagefind-ignore>
    <button class="mobile-menu__close" id="mobile-menu-close" aria-label="Close menu">✕</button>

    <!-- Search (mobile) -->
    <form class="mobile-search" action="/search" method="get" role="search">
      <input
        type="search"
        id="mobile-search-input"
        name="q"
        class="mobile-search__input"
        placeholder="Search stages, towns…"
        autocomplete="off"
        aria-label="Search the site"
      />
    </form>
    <div class="mobile-search__results" id="mobile-search-results" hidden></div>

    <nav>
      <ul class="mobile-menu__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={activeRoute === link.key ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-menu__footer">
      <span class="cg-caption">EN ▾</span>
      <button class="site-nav__subscribe">Subscribe</button>
    </div>
  </div>
  <div class="mobile-menu-backdrop" id="mobile-menu-backdrop"></div>

  <!-- Desktop search modal -->
  <div class="search-modal" id="search-modal" aria-hidden="true" role="dialog" aria-label="Search" data-pagefind-ignore>
    <form class="search-modal__box" action="/search" method="get" role="search">
      <input
        type="search"
        id="desktop-search-input"
        name="q"
        class="search-modal__input"
        placeholder="Search stages, towns, routes…"
        autocomplete="off"
        aria-label="Search the site"
      />
      <button type="button" class="search-modal__close" id="search-modal-close" aria-label="Close search">✕</button>
    </form>
    <div class="search-modal__results" id="desktop-search-results"></div>
  </div>
  <div class="search-modal-backdrop" id="search-modal-backdrop"></div>

  <!-- Mobile chrome -->
  <header class={`site-chrome site-chrome--${pageType}`} role="banner" data-pagefind-ignore>
    <a href="/" class="site-chrome__logo" aria-label="The Camino Guide — Home">
      <img src="/logo-wordmark.svg" alt="The Camino Guide" height="28" />
    </a>
    <div class="site-chrome__right">
      {breadcrumb && (
        <a href={breadcrumbUrl} class="site-chrome__back">
          <span aria-hidden>‹</span> {breadcrumb}
        </a>
      )}
      <button class="site-chrome__menu" id="mobile-menu-open" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Desktop nav -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation" data-pagefind-ignore>
    <div class="site-nav__left">
      <a href="/" class="site-nav__brand" aria-label="The Camino Guide — Home">
        <img src="/logo-wordmark.svg" alt="The Camino Guide" height="36" />
      </a>
      <ul class="site-nav__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={activeRoute === link.key ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="site-nav__right">
      <button class="site-nav__search" id="desktop-search-open" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <span class="site-nav__lang cg-caption">EN ▾</span>
      <button class="site-nav__subscribe">Subscribe</button>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer" role="contentinfo" data-pagefind-ignore>
    <p class="site-footer__caption">thecaminoguide.com</p>
  </footer>

  <script>
    // ── Mobile menu ───────────────────────────────────────────────────────────
    const openBtn  = document.getElementById('mobile-menu-open');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu     = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');

    function openMenu() {
      menu?.classList.add('is-open');
      backdrop?.classList.add('is-visible');
      document.body.classList.add('menu-open');
      openBtn?.setAttribute('aria-expanded', 'true');
      menu?.setAttribute('aria-hidden', 'false');
      closeBtn?.focus();
    }

    function closeMenu() {
      menu?.classList.remove('is-open');
      backdrop?.classList.remove('is-visible');
      document.body.classList.remove('menu-open');
      openBtn?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      openBtn?.focus();
    }

    openBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    // ── Desktop search modal ──────────────────────────────────────────────────
    const searchOpenBtn   = document.getElementById('desktop-search-open');
    const searchCloseBtn  = document.getElementById('search-modal-close');
    const searchModal     = document.getElementById('search-modal');
    const searchBackdrop  = document.getElementById('search-modal-backdrop');
    const desktopInput    = document.getElementById('desktop-search-input') as HTMLInputElement | null;

    function openSearchModal() {
      searchModal?.classList.add('is-open');
      searchBackdrop?.classList.add('is-visible');
      document.body.classList.add('menu-open');
      searchModal?.setAttribute('aria-hidden', 'false');
      desktopInput?.focus();
    }

    function closeSearchModal() {
      searchModal?.classList.remove('is-open');
      searchBackdrop?.classList.remove('is-visible');
      document.body.classList.remove('menu-open');
      searchModal?.setAttribute('aria-hidden', 'true');
      if (desktopInput) desktopInput.value = '';
      const results = document.getElementById('desktop-search-results');
      if (results) results.innerHTML = '';
    }

    searchOpenBtn?.addEventListener('click', openSearchModal);
    searchCloseBtn?.addEventListener('click', closeSearchModal);
    searchBackdrop?.addEventListener('click', closeSearchModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMenu(); closeSearchModal(); }
    });

    // ── Pagefind search ───────────────────────────────────────────────────────
    let pagefind: any = null;

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        const dynamicImport = new Function('p', 'return import(p)');
        pagefind = await dynamicImport('/pagefind/pagefind.js');
        await pagefind.init();
      } catch {
        pagefind = null;
      }
      return pagefind;
    }

    function renderResults(results: any[], container: HTMLElement) {
      if (!results.length) {
        container.innerHTML = '<p class="search-empty">No results found.</p>';
        return;
      }
      container.innerHTML = results
        .slice(0, 8)
        .map(r => `
          <a class="search-result" href="${r.url}">
            <span class="search-result__title">${r.meta?.title ?? 'Page'}</span>
            <span class="search-result__excerpt">${r.excerpt}</span>
          </a>
        `)
        .join('');
    }

    async function handleSearch(input: HTMLInputElement, container: HTMLElement) {
      const query = input.value.trim();
      if (!query) { container.hidden = true; container.innerHTML = ''; return; }

      const pf = await loadPagefind();
      if (!pf) { container.hidden = true; return; }

      const search = await pf.search(query);
      const data = await Promise.all(search.results.map((r: any) => r.data()));
      container.hidden = false;
      renderResults(data, container);
    }

    // Mobile search
    const mobileInput   = document.getElementById('mobile-search-input') as HTMLInputElement | null;
    const mobileResults = document.getElementById('mobile-search-results') as HTMLElement | null;

    let mobileTimer: ReturnType<typeof setTimeout>;
    mobileInput?.addEventListener('input', () => {
      clearTimeout(mobileTimer);
      mobileTimer = setTimeout(() => {
        if (mobileInput && mobileResults) handleSearch(mobileInput, mobileResults);
      }, 250);
    });

    // Desktop search
    const desktopResults = document.getElementById('desktop-search-results') as HTMLElement | null;

    let desktopTimer: ReturnType<typeof setTimeout>;
    desktopInput?.addEventListener('input', () => {
      clearTimeout(desktopTimer);
      desktopTimer = setTimeout(() => {
        if (desktopInput && desktopResults) handleSearch(desktopInput, desktopResults);
      }, 250);
    });
  </script>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
