---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  breadcrumb?: string;
  breadcrumbUrl?: string;
  activeRoute?: string;
  pageType?: 'home' | 'route' | 'stage' | 'locality';
}

const {
  title,
  description = 'The definitive English-language guide to the Camino de Santiago.',
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  breadcrumb,
  breadcrumbUrl = '/',
  activeRoute,
  pageType = 'home',
} = Astro.props;

const siteName = 'The Camino Guide';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const navLinks = [
  { label: 'French Way',      href: '/french-way',      key: 'french-way' },
  { label: 'Portuguese Way',  href: '/portuguese-way',  key: 'portuguese-way' },
  { label: 'Northern Way',    href: '/northern-way',    key: 'northern-way' },
  { label: 'Le Puy',          href: '/le-puy',          key: 'le-puy' },
  { label: 'Services',        href: '/services',        key: 'services' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type"        content={ogType} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:site_name"   content={siteName} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: Source Serif 4 + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- Mobile chrome -->
  <header class={`site-chrome site-chrome--${pageType}`} role="banner">
    <a href="/" class="site-chrome__logo" aria-label="The Camino Guide — Home">
      <img src="/logo-wordmark.svg" alt="The Camino Guide" height="28" />
    </a>
    <div class="site-chrome__right">
      {breadcrumb && (
        <a href={breadcrumbUrl} class="site-chrome__back">
          <span aria-hidden>‹</span> {breadcrumb}
        </a>
      )}
      <button class="site-chrome__menu" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Desktop nav -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <div class="site-nav__left">
      <a href="/" class="site-nav__brand" aria-label="The Camino Guide — Home">
        <img src="/logo-wordmark.svg" alt="The Camino Guide" height="36" />
      </a>
      <ul class="site-nav__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={activeRoute === link.key ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="site-nav__right">
      <span class="site-nav__lang cg-caption">EN ▾</span>
      <button class="site-nav__subscribe">Subscribe</button>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer" role="contentinfo">
    <p class="site-footer__caption">thecaminoguide.com</p>
  </footer>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
