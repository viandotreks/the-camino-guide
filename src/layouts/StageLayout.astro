---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  stage: CollectionEntry<'stages'>;
  activeTab?: 'guide' | 'services' | 'culture';
}

const { stage, activeTab = 'guide' } = Astro.props;
const s = stage.data;

// CSS class for diff-badge — derived from raw Notion bullet value
const difficultyClass: Record<string, string> = {
  '●●●●● (hardest)': 'very-hard',
  '●●●●○ (hard)':    'hard',
  '●●●○○ (medium)':  'moderate',
  '●●○○○ (easy)':    'easy',
  '●○○○○ (easiest)': 'easiest',
};
const diffClass = difficultyClass[s.difficulty] ?? 'moderate';

// Format elevation
const gainStr = `+${s.elevation_gain_m.toLocaleString('en-US')} m`;
const lossStr = `−${s.elevation_loss_m.toLocaleString('en-US')} m`;

// Format grade: show "+X% / −Y%" when both directions available
function gradeValue(up?: string | null, down?: string | null): string | null {
  if (!up && !down) return null;
  return [up ? `+${up}%` : null, down ? `−${down}%` : null].filter(Boolean).join(' / ');
}

// Sidebar / panel rows
const fmtNum = (n: number) => Number(n.toFixed(1));
const distStr = s.distance_mi
  ? `${fmtNum(s.distance_km)} km · ${fmtNum(s.distance_mi)} mi`
  : `${fmtNum(s.distance_km)} km`;
const maxGradeStr = gradeValue(s.max_slope_pct, s.max_slope_pct_down);
const avgGradeStr = gradeValue(s.avg_slope_pct, s.avg_slope_pct_down);

const dataRows = [
  { label: 'Distance',    value: distStr },
  { label: 'Elev. gain',  value: gainStr },
  { label: 'Elev. loss',  value: lossStr },
  maxGradeStr ? { label: 'Max grade', value: maxGradeStr } : null,
  avgGradeStr ? { label: 'Avg grade', value: avgGradeStr } : null,
  { label: 'Walking',     value: s.estimated_time_h },
].filter(Boolean) as { label: string; value: string }[];

const panelPreview = `${s.distance_km} km · ${gainStr}`;

// ── Services ──────────────────────────────────────────────────────────────────

type SvcItem = NonNullable<typeof s.services>[number];

const SVG_ATTR = `width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:inline;vertical-align:-3px;flex-shrink:0"`;

function typeIconSvg(type: string): string {
  if (type === 'Accommodation')
    return `<svg ${SVG_ATTR}><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>`;
  if (type === 'Restaurant')
    return `<svg ${SVG_ATTR.replace('stroke-width="2"', 'stroke-width="2.75"')}><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`;
  if (type === 'Cafe' || type === 'Bar')
    return `<svg ${SVG_ATTR}><path d="M17 11h1a3 3 0 0 1 0 6h-1"/><path d="M9 12v6"/><path d="M13 12v6"/><path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.72.5-2.5.5a2.5 2.5 0 0 1 0-5c.78 0 1.57.5 2.5.5S9.44 2 11 2s2 1.5 3 1.5 1.72-.5 2.5-.5a2.5 2.5 0 0 1 0 5c-.78 0-1.5-.5-2.5-.5Z"/><path d="M5 8v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/></svg>`;
  if (type === 'Pilgrim Reception')
    return `<svg ${SVG_ATTR}><path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762"/></svg>`;
  if (type === 'Shop' || type === 'Supermarket')
    return `<svg ${SVG_ATTR}><path d="m15 11-1 9"/><path d="m19 11-4-7"/><path d="M2 11h20"/><path d="m3.5 11 1.6 7.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6l1.7-7.4"/><path d="M4.5 15.5h15"/><path d="m5 11 4-7"/><path d="m9 11 1 9"/></svg>`;
  return '';
}

function siteLabel(url: string): string {
  try { return new URL(url).hostname.replace(/^www\./, ''); }
  catch { return url; }
}

// Group services by km_marker, sorted ascending (no km → end)
const serviceGroups: Array<{ km: number | null; items: SvcItem[] }> = [];
if (s.services?.length) {
  const map = new Map<string, SvcItem[]>();
  for (const svc of s.services) {
    const key = svc.km_marker != null ? String(svc.km_marker) : '__none__';
    if (!map.has(key)) map.set(key, []);
    map.get(key)!.push(svc);
  }
  for (const [key, items] of [...map.entries()].sort(([a], [b]) => {
    if (a === '__none__') return 1;
    if (b === '__none__') return -1;
    return Number(a) - Number(b);
  })) {
    serviceGroups.push({ km: key === '__none__' ? null : Number(key), items });
  }
}

// Fetch prev/next stage titles for seq-nav
const allStages = await getCollection('stages');
const prevStage = s.prev_stage_slug
  ? allStages.find(st => st.slug === s.prev_stage_slug)
  : null;
const nextStage = s.next_stage_slug
  ? allStages.find(st => st.slug === s.next_stage_slug)
  : null;

// Alternative / main route link
const isAlt = s.track_type === 'Alternative';
const altStage = isAlt
  ? allStages.find(st => st.data.route === s.route && st.data.order === s.branch_from && st.data.track_type !== 'Alternative')
  : allStages.find(st => st.data.route === s.route && st.data.branch_from === s.order && st.data.track_type === 'Alternative')
  ?? null;
---

<BaseLayout
  title={s.title}
  description={s.seo_description ?? `Stage guide: ${s.title}. ${s.distance_km} km, ${gainStr}. Difficulty: ${s.difficulty}.`}
  breadcrumb="French Way"
  breadcrumbUrl={`/${s.route}`}
  activeRoute={s.route}
  pageType="stage"
>

  <span data-pagefind-meta="type:Stage" hidden></span>

  <!-- Page header -->
  <header class="page-header" data-pagefind-ignore>
    <div class="page-header__inner">
      <div>
        <div class="page-header__eyebrow">
          <a href={`/${s.route}`}>{s.route === 'french-way' ? 'French Way' : s.route}</a>
          <span class="page-header__eyebrow-sep cg-eyebrow">·</span>
          <span class="cg-eyebrow">Stage {s.order}</span>
        </div>

        <!-- Mobile h1: stacked layout -->
        <h1 class="hide-on-desktop">
          {s.start_locality}
          <span class="page-header__to">to</span>
          {s.end_locality}
        </h1>

        <!-- Desktop h1: inline layout -->
        <h1 class="hide-on-mobile">
          {s.start_locality}
          <span class="page-header__to">to</span>
          {s.end_locality}
        </h1>

        {s.end_locality && (
          <span class="page-header__alt cg-data"></span>
        )}
      </div>

      <!-- Stats — desktop (right-aligned column) -->
      <div class="page-header__stats hide-on-mobile">
        <div class="page-header__stats-row">
          <span class={`diff-badge diff-badge--${diffClass} diff-badge--lg`}>
            {s.difficulty}
          </span>
          <span class="page-header__divider-desk"></span>
          <div style="text-align: right;">
            <div class="page-header__dist">{s.distance_km} km</div>
            <div class="page-header__elev">{s.estimated_time_h} · {gainStr}</div>
          </div>
        </div>
      </div>
    </div>

  </header>

  <!-- Cartography -->
  <div class={`map-area${s.cartography_url ? ' map-area--cartography' : ''}`} data-pagefind-ignore>
    {s.cartography_url ? (
      <div class="map-area__body">
        <img
          id="cartography-img"
          src={s.cartography_url}
          alt={`Route map for ${s.title}`}
          class="map-area__cartography"
          loading="lazy"
          decoding="async"
          style="cursor: zoom-in;"
        />
      </div>
    ) : (
      <div class="map-area__placeholder">Route map coming soon</div>
    )}
  </div>

  <!-- Map actions -->
  {(s.cartography_url || s.map_url) && (
    <div data-pagefind-ignore>
      {s.cartography_url && (
        <p class="carto-hint">Double-tap image to enlarge</p>
      )}
      <div class="map-actions">
        {s.cartography_url && (
          <button class="map-btn" id="open-legend-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            Map Legend
          </button>
        )}
        {s.map_url && (
          <a class="map-btn map-btn--link" href={s.map_url} target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 19 21 12 17 5 21 12 2"/></svg>
            Interactive Map
          </a>
        )}
      </div>
    </div>
  )}

  <!-- Cartography fullscreen overlay (double-tap / double-click on image) -->
  {s.cartography_url && (
    <div id="cartography-overlay" class="carto-overlay" hidden aria-modal="true" role="dialog">
      <button class="carto-overlay__close" id="close-cartography-btn" aria-label="Close">✕</button>
      <img src={s.cartography_url} alt={`Route map for ${s.title}`} class="carto-overlay__img" />
    </div>
  )}

  <!-- Map Legend modal -->
  {s.cartography_url && (
    <div id="legend-overlay" class="legend-overlay" hidden aria-modal="true" role="dialog">
      <div class="legend-modal">
        <button class="legend-modal__close" id="close-legend-btn" aria-label="Close">✕</button>
        <h2 class="legend-modal__title">Map Legend</h2>
        <div class="legend-grid">

          <!-- Lines -->
          <div class="legend-section">
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 8" aria-hidden="true"><line x1="0" y1="4" x2="36" y2="4" stroke="#F0A500" stroke-width="3" stroke-linecap="round"/></svg>
              <span>Camino (main way)</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 8" aria-hidden="true"><line x1="0" y1="4" x2="36" y2="4" stroke="#F0A500" stroke-width="2.5" stroke-dasharray="6,4" stroke-linecap="round"/></svg>
              <span>Alternative way</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 8" aria-hidden="true"><line x1="0" y1="4" x2="36" y2="4" stroke="#D97070" stroke-width="2" stroke-dasharray="9,4" stroke-linecap="round"/></svg>
              <span>Border</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 8" aria-hidden="true"><line x1="0" y1="4" x2="36" y2="4" stroke="#90C8F0" stroke-width="2" stroke-linecap="round"/></svg>
              <span>River</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 12" aria-hidden="true"><rect x="0" y="2" width="36" height="8" fill="#A8D8F0" rx="1"/></svg>
              <span>Coastline</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 8" aria-hidden="true"><line x1="0" y1="4" x2="36" y2="4" stroke="#333" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>Paved road</span>
            </div>
            <div class="legend-item">
              <svg class="leg-line" viewBox="0 0 36 12" aria-hidden="true"><line x1="0" y1="6" x2="36" y2="6" stroke="#333" stroke-width="1.5"/><line x1="5" y1="2" x2="5" y2="10" stroke="#333" stroke-width="1.5"/><line x1="13" y1="2" x2="13" y2="10" stroke="#333" stroke-width="1.5"/><line x1="21" y1="2" x2="21" y2="10" stroke="#333" stroke-width="1.5"/><line x1="29" y1="2" x2="29" y2="10" stroke="#333" stroke-width="1.5"/></svg>
              <span>Tracks</span>
            </div>
            <div class="legend-item">
              <span class="leg-bri" aria-hidden="true"><svg width="14" height="10" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="4" cy="10" r="3"/><circle cx="16" cy="10" r="3"/><path d="M4 10 L7 4 L12 4 L16 10"/><path d="M10 10 L7 4"/><path d="M12 4 L14 7"/></svg> <em>BRI</em></span>
              <span>Bike recommended itinerary</span>
            </div>
          </div>

          <!-- Icons -->
          <div class="legend-section">
            <div class="legend-item">
              <span class="leg-badge">A</span>
              <span>Accommodation</span>
            </div>
            <div class="legend-item">
              <span class="leg-badge">S</span>
              <span>Multiple services</span>
            </div>
            <div class="legend-item">
              <span class="leg-badge">F</span>
              <span>Fountain</span>
            </div>
            <div class="legend-item">
              <span class="leg-char leg-char--poi">✱</span>
              <span>Point of interest</span>
            </div>
            <div class="legend-item">
              <span class="leg-char">▲</span>
              <span>Height / Pass</span>
            </div>
            <div class="legend-item">
              <span class="leg-badge leg-badge--danger">!</span>
              <span>Danger</span>
            </div>
            <div class="legend-item">
              <span class="leg-dir" aria-hidden="true">❮</span>
              <span>Direction of travel</span>
            </div>
            <div class="legend-item">
              <span class="leg-dist">15.0</span>
              <span>Distance</span>
            </div>
          </div>

          <!-- Text styles -->
          <div class="legend-section legend-section--text">
            <div class="legend-item legend-item--text">
              <strong class="leg-city">City / Town</strong>
            </div>
            <div class="legend-item legend-item--text">
              <em class="leg-poi-text">Point of relevance</em>
            </div>
            <div class="legend-item legend-item--text">
              <span class="leg-river-text">River / Sea</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  )}

  <!-- Sticky tab bar -->
  <div class="tab-bar tab-bar--3" role="tablist" id="stage-tabs" data-pagefind-ignore>
    <button
      class="tab-bar__btn"
      role="tab"
      aria-selected={activeTab === 'guide' ? 'true' : 'false'}
      data-tab="guide"
    >
      The Guide
    </button>
    <button
      class="tab-bar__btn"
      role="tab"
      aria-selected={activeTab === 'services' ? 'true' : 'false'}
      data-tab="services"
    >
      Services
    </button>
    <button
      class="tab-bar__btn tab-bar__btn--soon"
      role="tab"
      aria-selected="false"
      data-tab="culture"
    >
      Culture &amp; POIs
      <span class="tab-bar__soon">Soon</span>
    </button>
  </div>

  <!-- Stage grid: sidebar (desktop) + article -->
  <div class="stage-grid">

    <!-- Sidebar: visible on desktop only -->
    <aside class="sidebar" aria-label="Stage data" data-pagefind-ignore>
      <div class="sidebar__title">Stage data</div>
      {dataRows.map((row, i) => (
        <div class={`sidebar__row${i === dataRows.length - 1 ? ' sidebar__row--last' : ''}`}>
          <span class="sidebar__label">{row.label}</span>
          <span class="sidebar__value">{row.value}</span>
        </div>
      ))}
      <div class="sidebar__row">
        <span class="sidebar__label">Difficulty</span>
        <span class="sidebar__value">
          <span class={`diff-badge diff-badge--${diffClass}`}>
            {s.difficulty}
          </span>
        </span>
      </div>
      {s.last_verified && (
        <div class="sidebar__row sidebar__row--last">
          <span class="sidebar__label">Verified</span>
          <span class="sidebar__value" style="font-size: 12px; color: var(--ink-3);">
            {s.last_verified}
          </span>
        </div>
      )}
    </aside>

    <!-- Content article -->
    <article class="stage-content">

      <!-- Tab panel: The Guide -->
      <div id="tab-guide" class="tab-panel" data-tab="guide" role="tabpanel">

        <!-- Mobile collapsible data panel (open by default) -->
        <details class="data-panel" open data-pagefind-ignore>
          <summary>
            <div class="data-panel__label-row">
              <span class="cg-eyebrow data-panel__title">Stage Data</span>
              <span class="data-panel__preview">{panelPreview}</span>
            </div>
            <span class="data-panel__icon" aria-hidden></span>
          </summary>
          <div class="data-panel__body">
            {dataRows.map((row, i) => (
              <div class={`data-panel__row${i === dataRows.length - 1 ? ' data-panel__row--last' : ''}`}>
                <span class="data-panel__key">{row.label}</span>
                <span class="data-panel__val">{row.value}</span>
              </div>
            ))}
            <div class="data-panel__row">
              <span class="data-panel__key">Difficulty</span>
              <span class="data-panel__val">
                <span class={`diff-badge diff-badge--${diffClass}`}>
                  {s.difficulty}
                </span>
              </span>
            </div>
            {s.last_verified && (
              <div class="data-panel__row data-panel__row--last">
                <span class="data-panel__key">Verified</span>
                <span class="data-panel__val" style="font-size: 12px; color: var(--ink-3);">
                  {s.last_verified}
                </span>
              </div>
            )}
          </div>
        </details>

        <!-- Guide content (from [slug].astro slot) -->
        <slot />

      </div>

      <!-- Tab panel: Services -->
      <div id="tab-services" class="tab-panel" data-tab="services" role="tabpanel" hidden data-pagefind-ignore>
        {serviceGroups.length > 0 ? (
          <div class="svc-list">

            <!-- Icon key -->
            <details class="svc-icon-key">
              <summary class="svc-icon-key__toggle">Icon key</summary>
              <ul class="svc-icon-key__list">
                <li><span set:html={typeIconSvg('Accommodation')} /> Accommodation (shared or private)</li>
                <li><span set:html={typeIconSvg('Restaurant')} /> Restaurant and eating houses with daily menu / different options</li>
                <li><span set:html={typeIconSvg('Cafe')} /> Cafes and taverns with limited meal options</li>
                <li><span set:html={typeIconSvg('Pilgrim Reception')} /> Pilgrims reception, help point</li>
                <li><span set:html={typeIconSvg('Shop')} /> Shop / Store</li>
              </ul>
            </details>

            <!-- Stage-specific intro -->
            {s.services_intro && (
              <div class="svc-intro prose" set:html={s.services_intro} />
            )}
            {serviceGroups.map(group => (
              <div class="svc-group">
                {group.km != null && (
                  <div class="svc-group__km">
                    <span class="km-marker">{group.km}</span>
                    {group.items[0]?.location && (
                      <span class="svc-group__location">{group.items[0].location}</span>
                    )}
                  </div>
                )}
                <ul class="svc-cards">
                  {group.items.map(svc => (
                    <li class="svc-card">
                      <p class="svc-card__body">
                        <span class="svc-card__icons" set:html={svc.type.map(typeIconSvg).join(' ')} />{' '}<strong class="svc-card__name">{svc.name}</strong>{svc.address ? <span class="svc-card__addr">{svc.address}</span> : null}{svc.description ? <span class="svc-card__desc">{svc.description}</span> : null}
                        {(svc.phone || svc.booking_url || svc.website) && (
                          <span class="svc-card__links">
                            {svc.phone && (
                              <a href={`tel:${svc.phone}`} class="svc-card__phone">{' '}{svc.phone}</a>
                            )}
                            {svc.phone && (svc.booking_url || svc.website) && (
                              <span class="svc-card__sep">{' | '}</span>
                            )}
                            {svc.booking_url ? (
                              <a href={svc.booking_url} class="svc-card__book" target="_blank" rel="noopener noreferrer">Book now</a>
                            ) : svc.website ? (
                              <a href={svc.website} class="svc-card__site" target="_blank" rel="noopener noreferrer">{siteLabel(svc.website)}</a>
                            ) : null}
                          </span>
                        )}
                      </p>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ) : (
          <div class="coming-soon">
            <div class="coming-soon__heading">Accommodation &amp; Services</div>
            <p>Lodging data for this stage is being added. Check back soon.</p>
            <div class="coming-soon__caption">In preparation — 2026</div>
          </div>
        )}
      </div>

      <!-- Tab panel: Culture & POIs -->
      <div id="tab-culture" class="tab-panel" data-tab="culture" role="tabpanel" hidden data-pagefind-ignore>
        <div class="coming-soon">
          <div class="coming-soon__heading">Culture &amp; POIs</div>
          <p>Field notes on the churches, ruins, monasteries and small museums along this stage. In preparation.</p>
          <div class="coming-soon__caption">Available to subscribers — Q3 2026</div>
        </div>
      </div>

      <!-- Sequential navigation -->
      <nav class={`seq-nav${altStage ? ' seq-nav--with-alt' : ''}`} aria-label="Adjacent stages" data-pagefind-ignore>

        {/* Alternative row — mobile: full width above; desktop: middle column */}
        {altStage && (
          <a href={`/${s.route}/${altStage.slug}`} class="seq-nav__link seq-nav__link--alt">
            <span class="seq-nav__label">{isAlt ? '← Main route' : 'Alternative route →'}</span>
            <span class="seq-nav__title">{altStage.data.title}</span>
          </a>
        )}

        {/* Prev / Next row */}
        {s.prev_stage_slug ? (
          <a href={`/${s.route}/${s.prev_stage_slug}`} class="seq-nav__link">
            <span class="seq-nav__label">← Previous</span>
            <span class="seq-nav__title">
              {prevStage?.data.title ?? s.prev_stage_slug.replace(/-/g, ' ')}
            </span>
          </a>
        ) : (
          <span></span>
        )}
        <span class="seq-nav__divider"></span>
        {s.next_stage_slug ? (
          <a href={`/${s.route}/${s.next_stage_slug}`} class="seq-nav__link seq-nav__link--next">
            <span class="seq-nav__label">Next →</span>
            <span class="seq-nav__title">
              {nextStage?.data.title ?? s.next_stage_slug.replace(/-/g, ' ')}
            </span>
          </a>
        ) : (
          <span></span>
        )}
      </nav>

    </article>
  </div>

</BaseLayout>

<!-- Tab switching -->
<script>
  // ── Cartography fullscreen (double-tap / dblclick on image) ──
  const cartoImg   = document.getElementById('cartography-img');
  const closeBtn   = document.getElementById('close-cartography-btn');
  const overlay    = document.getElementById('cartography-overlay');

  if (cartoImg && overlay) {
    let lastTap = 0;
    cartoImg.addEventListener('click', () => {
      const now = Date.now();
      if (now - lastTap < 350) {
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      lastTap = now;
    });
    cartoImg.addEventListener('dblclick', () => {
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
    });
  }
  if (closeBtn && overlay) {
    closeBtn.addEventListener('click', () => {
      overlay.hidden = true;
      document.body.style.overflow = '';
    });
  }

  // ── Legend modal ───────────────────────────────────────────
  const openLegendBtn   = document.getElementById('open-legend-btn');
  const closeLegendBtn  = document.getElementById('close-legend-btn');
  const legendOverlay   = document.getElementById('legend-overlay');

  if (openLegendBtn && legendOverlay) {
    openLegendBtn.addEventListener('click', () => {
      legendOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
    });
  }
  if (closeLegendBtn && legendOverlay) {
    closeLegendBtn.addEventListener('click', () => {
      legendOverlay.hidden = true;
      document.body.style.overflow = '';
    });
    legendOverlay.addEventListener('click', (e: MouseEvent) => {
      if (e.target === legendOverlay) { legendOverlay.hidden = true; document.body.style.overflow = ''; }
    });
  }

  // ── Escape closes any open overlay ────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      if (overlay && !overlay.hidden) { overlay.hidden = true; document.body.style.overflow = ''; }
      if (legendOverlay && !legendOverlay.hidden) { legendOverlay.hidden = true; document.body.style.overflow = ''; }
    }
  });

  const tabBar = document.getElementById('stage-tabs');
  if (tabBar) {
    const btns   = tabBar.querySelectorAll<HTMLButtonElement>('.tab-bar__btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        btns.forEach(b => b.setAttribute('aria-selected', String(b === btn)));
        panels.forEach(p => { p.hidden = p.dataset.tab !== target; });
      });
    });
  }
</script>

